<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FaseehFS</title>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <main class="container">
      <header class="hero">
        <h1>Hi there 👋</h1>
        <p class="subtitle">
          I’m Faseeh. I’m currently learning full-stack web development with
          Next.js.
        </p>
        <div class="hero-links">
          <a href="https://github.com/faseehfs-dev/" target="_blank"
            >GitHub Profile</a
          >
          <a
            href="https://github.com/faseehfs-dev?tab=repositories"
            target="_blank"
            >Repositories</a
          >
          <a href="https://faseehfs.itch.io" target="_blank">Itch.io Games</a>
        </div>
      </header>

      <section class="section">
        <h2>🎮 My games</h2>

        <div class="card">
          <h3>The Stellar Expedition</h3>
          <p>
            A Godot game where you drift through space to reach your station.
          </p>
          <a
            href="https://faseehfs.itch.io/the-stellar-expedition/"
            target="_blank"
            >View on Itch.io</a
          >
        </div>

        <div class="card">
          <h3>Apple Jump</h3>
          <p>A Unity game where you jump over apples on your way to space.</p>
          <a href="https://faseehfs.itch.io/apple-jump/" target="_blank"
            >View on Itch.io</a
          >
        </div>
      </section>

      <section class="section">
        <h2>📂 My Repositories</h2>

        {% for repo in repos.mainRepos %}
          <div class="card">
            <h3>{{ repo.name }}</h3>

            {% if repo.description %}
              <p>{{ repo.description }}</p>
            {% endif %}

            <p style="font-size: 0.9rem; opacity: 0.7;">
              ⭐ {{ repo.stargazers_count }} • Updated {{ repo.updated_at }}
            </p>

            <a href="{{ repo.html_url }}" target="_blank">View on GitHub</a>
          </div>
        {% endfor %}
      </section>

      <section class="section">
        <h2>📜 Archived Repositories</h2>

        {% for repo in repos.archivedRepos %}
          <div class="card">
            <h3>{{ repo.name }}</h3>

            {% if repo.description %}
              <p>{{ repo.description }}</p>
            {% endif %}

            <p style="font-size: 0.9rem; opacity: 0.7;">
              ⭐ {{ repo.stargazers_count }} • Updated {{ repo.updated_at }}
            </p>

            <a href="{{ repo.html_url }}" target="_blank">View on GitHub</a>
          </div>
        {% endfor %}
      </section>

      <footer class="footer">
        <p>Thanks for visiting 🥳</p>
      </footer>
    </main>
  </body>
</html>
